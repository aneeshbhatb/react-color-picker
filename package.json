{
  "name": "@aneeshbhat/react-color-picker",
  "version": "0.1.0-alpha.3",
  "description": "A simple React color picker with solid and gradient color support.",
  "license": "MIT",
  "author": "Aneesh Bhat",
  "keywords": [
    "react",
    "color-picker",
    "gradient",
    "color",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "private": false,
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "module": "./dist/react-color-picker.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/react-color-picker.js"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "build": "bun run lint && bun run format:check && vite build && tsc -p tsconfig.json",
    "lint": "eslint . && stylelint \"src/**/*.css\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-prettier": "^5.0.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14"
  },
  "homepage": "https://aneeshbhatb.github.io/react-color-picker-playground/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aneeshbhatb/react-color-picker.git"
  },
  "bugs": {
    "url": "https://github.com/aneeshbhatb/react-color-picker/issues"
  }
}
